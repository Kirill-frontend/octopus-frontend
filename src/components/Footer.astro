---
import "../assets/footer.css";
import CmsImage from "./shared/CmsImage.astro";
import {
  resolveLinkHref,
  resolvePayloadMediaAlt,
  resolvePayloadMediaUrl,
} from "../lib/payload";

const { data } = Astro.props;

const mainPages = data?.mainLinks?.map((item) => ({
  href: resolveLinkHref(item),
  label: item.label,
})) ?? [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/services", label: "Services" },
  { href: "/blog", label: "Blog" },
  { href: "/contact", label: "Contact" },
];

const utilityPages =
  data?.utilityLinks?.map((item) => ({
    href: resolveLinkHref(item),
    label: item.label,
  })) ?? [];

const newsletterTitle = data?.newsletterTitle || "Subscribe to our newsletter";
const newsletterText =
  data?.newsletterText ||
  "Get company updates, project news, and fresh engineering insights in your inbox.";
const newsletterEnabled = data?.newsletterFormEnabled ?? true;
const logoUrl = resolvePayloadMediaUrl(data?.logo);
const logoAlt = resolvePayloadMediaAlt(data?.logo, "Octopus Group");
const copyrightText =
  data?.copyrightText ||
  `Copyright © Octopus Group ${new Date().getFullYear()}. All rights reserved.`;
---

<footer class="site-footer">
  <div class="site-footer__top">
    <div class="site-footer__container">
      <section
        class="site-footer__subscribe"
        aria-labelledby="footer-subscribe-title"
      >
        <div class="site-footer__subscribe-copy">
          <h2 id="footer-subscribe-title" class="site-footer__heading">
            {newsletterTitle}
          </h2>
          <p class="site-footer__text">{newsletterText}</p>
        </div>

        {
          newsletterEnabled && (
            <form class="site-footer__form">
              <label class="site-footer__sr-only" for="footer-email">
                Email address
              </label>
              <input
                id="footer-email"
                class="site-footer__input"
                type="email"
                name="email"
                placeholder="Email address"
                autocomplete="email"
                required
              />
              <button type="submit" class="site-footer__button">
                Subscribe
              </button>
            </form>
          )
        }
      </section>

      <nav class="site-footer__links" aria-label="Footer navigation">
        <div class="site-footer__link-group">
          <h3 class="site-footer__group-title">Main pages</h3>
          <ul class="site-footer__link-list">
            {
              mainPages.map((item) => (
                <li>
                  <a href={item.href} class="site-footer__link">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="site-footer__link-group">
          <h3 class="site-footer__group-title">Utility pages</h3>
          <ul class="site-footer__link-list">
            {
              utilityPages.map((item) => (
                <li>
                  <a href={item.href} class="site-footer__link">
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="site-footer__container site-footer__bottom-inner">
      <a
        href="/"
        class="site-footer__logo-link"
        aria-label="Octopus Group home"
      >
        <CmsImage
          src={logoUrl}
          alt={logoAlt}
          class="site-footer__logo"
          wrapperClass="site-footer__logo-wrap"
          placeholderLabel="Octopus Group"
        />
      </a>

      <p class="site-footer__copyright">{copyrightText}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer__logo-wrap {
    width: 148px;
    height: 34px;
    background: transparent;
  }

  .site-footer__logo-wrap :global(.cms-image__placeholder) {
    background: transparent;
    color: #ffffff;
    justify-content: flex-start;
    padding: 0;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
