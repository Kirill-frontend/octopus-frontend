---
const {
  src,
  alt = "Image",
  width,
  height,
  sizes,
  loading = "lazy",
  fetchpriority,
  class: imgClass,
  wrapperClass = "",
  fit = "cover",
  placeholderLabel = "Image unavailable",
  fallbackSrc,
} = Astro.props;

const hasImage = Boolean(src);
---

<div
  class:list={["cms-image", wrapperClass]}
  data-cms-image
  data-state={hasImage ? "loading" : "error"}
>
  {
    hasImage && (
      <img
        src={src}
        alt={alt}
        width={width}
        height={height}
        sizes={sizes}
        loading={loading}
        decoding="async"
        fetchpriority={fetchpriority}
        class={imgClass}
        style={{ objectFit: fit }}
        onload="this.closest('[data-cms-image]')?.setAttribute('data-state', 'loaded')"
        data-fallback-src={fallbackSrc}
        onerror="const root=this.closest('[data-cms-image]'); const fallback=this.dataset.fallbackSrc; const failedSrc=this.currentSrc || this.src; if(fallback && failedSrc !== fallback){ if(root){root.setAttribute('data-state','loading');} this.hidden=false; this.src=fallback; return; } const message=`CmsImage failed: ${failedSrc}`; console.error(message, { src: failedSrc, alt: this.alt }); if(root){root.setAttribute('data-state','error');} this.hidden=true;"
      />
    )
  }
  <div class="cms-image__placeholder" aria-hidden={hasImage ? "true" : "false"}>
    <span>{placeholderLabel}</span>
  </div>
</div>

<style>
  .cms-image {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .cms-image :global(img) {
    width: 100%;
    height: 100%;
    display: block;
  }

  .cms-image__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    color: rgba(14, 59, 91, 0.78);
    font-size: 0.95rem;
    line-height: 1.4;
    text-align: center;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.82),
      rgba(237, 242, 246, 0.96)
    );
    transition: opacity 0.25s ease;
  }

  .cms-image[data-state="loaded"] .cms-image__placeholder {
    opacity: 0;
    pointer-events: none;
  }
</style>
