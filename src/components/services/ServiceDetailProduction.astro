---
import CmsImage from "../shared/CmsImage.astro";
import "../../assets/services/service-detail-page.css";

const {
  title = "What we produce",
  cards = [],
  complianceItems = [],
  backgroundImage,
} = Astro.props;
---

<section class="service-detail-production">
  <div class="service-detail-production__top">
    {
      backgroundImage && (
        <div class="service-detail-production__background" aria-hidden="true">
          <CmsImage
            src={backgroundImage}
            alt=""
            wrapperClass="service-detail-production__background-media"
            class="service-detail-production__background-image"
            placeholderLabel=""
          />
        </div>
      )
    }
    <div class="service-detail-production__panel">
      <h2 class="service-detail-production__title">{title}</h2>

      <div class="service-detail-production__grid">
        {cards.map((card) => (
          <article class="service-detail-production__card">
            <span class="service-detail-production__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="service-detail-production__icon-svg">
                <path d="M12 3.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" fill="none" stroke="currentColor" stroke-width="1.6"></path>
                <path d="M10.1 12.9v3.8l1.9-1.1 1.9 1.1v-3.8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
            <p class="service-detail-production__card-text">{card}</p>
          </article>
        ))}
      </div>
    </div>
  </div>

  <div class="service-detail-production__bottom">
    <div class="service-detail-production__bottom-track">
      <div class="service-detail-production__compliance">
        {complianceItems.map((item) => (
          <div class="service-detail-production__compliance-item">
            <span class="service-detail-production__check" aria-hidden="true">
              <svg viewBox="0 0 24 24" class="service-detail-production__check-svg">
                <path d="m5.5 12.5 4.1 4.1 8.9-9.1" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </span>
            <p class="service-detail-production__compliance-text">{item}</p>
          </div>
        ))}
      </div>

      <div class="service-detail-production__placeholder" aria-hidden="true"></div>
    </div>
  </div>
</section>
