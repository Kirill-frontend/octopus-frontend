---
import "../../assets/services/service-detail-page.css";

const {
  title = "What we supply",
  cards = [],
} = Astro.props;
---

<section class="service-detail-supply">
  <div class="service-detail-page__container">
    <h2 class="service-detail-supply__title">{title}</h2>

    <div class="service-detail-supply__grid">
      {cards.map((card) => (
        <article class="service-detail-supply__card">
          <span class="service-detail-supply__icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="service-detail-supply__icon-svg">
              <path d="M12 3.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" fill="none" stroke="currentColor" stroke-width="1.6"></path>
              <path d="M10.1 12.9v3.8l1.9-1.1 1.9 1.1v-3.8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>

          <div class="service-detail-supply__body">
            <h3 class="service-detail-supply__card-title">{card.title}</h3>
            <div class="service-detail-supply__card-text">
              {card.lines?.map((line) => <p>{line}</p>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
