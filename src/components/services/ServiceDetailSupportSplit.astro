---
import "../../assets/services/service-detail-page.css";

const {
  leftLabel = "",
  leftItems = [],
  rightTitle = "",
  rightText = "",
} = Astro.props;
---

<section class="service-detail-support-split">
  <div class="service-detail-support-split__panel service-detail-support-split__panel--dark">
    <p class="service-detail-support-split__label">{leftLabel}</p>

    <div class="service-detail-support-split__list">
      {leftItems.map((item) => (
        <div class="service-detail-support-split__item">
          <span class="service-detail-support-split__bullet" aria-hidden="true">
            <svg viewBox="0 0 24 24" class="service-detail-support-split__bullet-svg">
              <path d="M12 3.5a4.5 4.5 0 1 0 0 9 4.5 4.5 0 0 0 0-9Z" fill="none" stroke="currentColor" stroke-width="1.6"></path>
              <path d="M10.1 12.9v3.8l1.9-1.1 1.9 1.1v-3.8" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </span>
          <p>{item}</p>
        </div>
      ))}
    </div>
  </div>

  <div class="service-detail-support-split__panel service-detail-support-split__panel--light">
    <div class="service-detail-support-split__copy">
      <h2>{rightTitle}</h2>
      {rightText && <p>{rightText}</p>}
    </div>
  </div>
</section>
