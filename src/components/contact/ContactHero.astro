---
import "../../assets/about/about-shared.css";
import "../../assets/contact/contact-hero.css";
import { resolvePayloadApiUrl } from "../../lib/payload";

const {
  data = {},
} = Astro.props;

const contactMethods = Array.isArray(data?.contactMethods)
  ? data.contactMethods
  : [
      {
        href: "mailto:info@cargo.com",
        label: "Send me an email",
        value: "info@cargo.com",
        icon: "email",
      },
      {
        href: "tel:+14149464530",
        label: "Give me a call",
        value: "(414) 946 - 4530",
        icon: "phone",
      },
    ];

const form = data?.form || {};
const leadEndpoint = resolvePayloadApiUrl("/api/leads");
---

<section class="contact-hero">
  <div class="contact-hero__container">
    <div class="contact-hero__grid">
      <div class="contact-hero__intro">
        <p class="about-eyebrow contact-hero__eyebrow">{data?.eyebrow || "Contact us"}</p>
        <h1 class="contact-hero__title">{data?.title || "Contact us"}</h1>
        <p class="contact-hero__description">
          {
            data?.description ||
              "Lorem ipsum dolor sit amet, consectetur adipiscing elit mauris donec dictum sit consequat auctor enim."
          }
        </p>

        <div class="contact-hero__methods" aria-label="Contact methods">
          {contactMethods.map((method) => (
            <a href={method.href} class="contact-hero__method">
              <span class="contact-hero__method-icon" aria-hidden="true">
                {
                  method.icon === "email" ? (
                    <svg viewBox="0 0 24 24" class="contact-hero__icon-svg">
                      <path
                        d="M4 7.5h16v9H4z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linejoin="round"
                      />
                      <path
                        d="m5 8 7 6 7-6"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  ) : (
                    <svg viewBox="0 0 24 24" class="contact-hero__icon-svg">
                      <path
                        d="M8.8 5.2c.4-.4 1-.5 1.5-.1l2.2 1.7c.5.4.6 1.1.2 1.6l-1.3 1.8a13.8 13.8 0 0 0 2.4 2.4l1.8-1.3c.5-.4 1.2-.3 1.6.2l1.7 2.2c.4.5.3 1.1-.1 1.5l-1 1c-.8.8-2 1.2-3.1.9-2-.5-4-1.8-6-3.8s-3.3-4-3.8-6c-.3-1.1.1-2.3.9-3.1l1-1Z"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.8"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      />
                    </svg>
                  )
                }
              </span>

              <span class="contact-hero__method-copy">
                <span class="contact-hero__method-label">{method.label}</span>
                <span class="contact-hero__method-value">{method.value}</span>
              </span>
            </a>
          ))}
        </div>
      </div>

      <div class="contact-hero__form-panel">
        <form
          class="contact-hero__form"
          data-lead-form
          data-lead-endpoint={leadEndpoint}
          data-success-message="Your message has been received. We will get back to you soon."
        >
          <label class="contact-hero__field">
            <span class="contact-hero__sr-only">Full name</span>
            <input
              type="text"
              name="name"
              placeholder={form.namePlaceholder || "Full name"}
              autocomplete="name"
              required
            />
          </label>
          <label class="contact-hero__field">
            <span class="contact-hero__sr-only">Email address</span>
            <input
              type="email"
              name="email"
              placeholder={form.emailPlaceholder || "Email address"}
              autocomplete="email"
              required
            />
          </label>
          <label class="contact-hero__field">
            <span class="contact-hero__sr-only">Phone number</span>
            <input
              type="tel"
              name="phone"
              placeholder={form.phonePlaceholder || "Phone number"}
              autocomplete="tel"
              required
            />
          </label>
          <label class="contact-hero__field">
            <span class="contact-hero__sr-only">Subject</span>
            <input
              type="text"
              name="subject"
              placeholder={form.subjectPlaceholder || "Subject"}
              required
            />
          </label>
          <label class="contact-hero__field contact-hero__field--full">
            <span class="contact-hero__sr-only">Message</span>
            <textarea
              name="message"
              placeholder={form.messagePlaceholder || "Please type your message here..."}
              rows="4"
            ></textarea>
          </label>

          <input type="hidden" name="submissionType" value="contact" />

          <button type="submit" class="about-button about-button--dark contact-hero__submit">
            {form.submitLabel || "Send message"}
          </button>
          <p class="contact-hero__form-status" data-lead-form-status aria-live="polite"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const leadForms = document.querySelectorAll("[data-lead-form]");

  const bindLeadForm = (form) => {
    if (!(form instanceof HTMLFormElement) || form.dataset.leadBound === "true") return;

    form.dataset.leadBound = "true";

    const status = form.querySelector("[data-lead-form-status]");
    const submitButton = form.querySelector('button[type="submit"]');
    const endpoint = form.dataset.leadEndpoint;
    const successMessage =
      form.dataset.successMessage || "Your form has been submitted successfully.";

    form.addEventListener("submit", async (event) => {
      event.preventDefault();

      if (!endpoint || !submitButton) return;

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      submitButton.disabled = true;
      submitButton.setAttribute("aria-busy", "true");

      if (status) {
        status.textContent = "Sending...";
        status.dataset.state = "pending";
      }

      try {
        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        const result = await response.json().catch(() => null);

        if (!response.ok || !result?.ok) {
          throw new Error(result?.error || "Unable to submit the form.");
        }

        form.reset();

        if (status) {
          status.textContent = successMessage;
          status.dataset.state = "success";
        }
      } catch (error) {
        if (status) {
          status.textContent =
            error instanceof Error ? error.message : "Unable to submit the form.";
          status.dataset.state = "error";
        }
      } finally {
        submitButton.disabled = false;
        submitButton.removeAttribute("aria-busy");
      }
    });
  };

  leadForms.forEach(bindLeadForm);
</script>
