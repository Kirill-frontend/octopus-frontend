---
import HomeBlock from "../components/HomeBlock.astro";
import Layout from "../layouts/Layout.astro";
import { getFooterData, getHeaderData, getHomePage, getSiteSettings } from "../lib/payload";

const [siteSettings, header, footer, homePage] = await Promise.all([
  getSiteSettings(),
  getHeaderData(),
  getFooterData(),
  getHomePage(),
]);
---

<Layout pageKey="home" seo={homePage?.seo} siteSettings={siteSettings} header={header} footer={footer}>
  <HomeBlock data={homePage} />
</Layout>
